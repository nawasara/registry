{
    "name": "nawasara/registry",
    "description": "Master data for OPD (organizational units), PIC (person-in-charge), and asset ownership across Nawasara packages.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "registry",
        "asset",
        "opd",
        "pic",
        "ownership"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/registry/issues",
        "source": "https://github.com/nawasara/registry"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\Registry\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-activitylog": "^4.9",
        "nawasara/ui": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Registry\\RegistryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
